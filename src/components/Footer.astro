---
const year = new Date().getFullYear();
const navLinks = [
  { href: '#work',    label: 'Work'  },
  { href: '#shop',    label: 'Shop'  },
  { href: '#about',   label: 'About' },
];
---

<footer class="border-t border-[#0A0A0A]/15 bg-[#F5F0E4]">
  <div class="flex items-center justify-between px-6 md:px-10 h-11">

    <!-- Brand + copyright -->
    <span class="label opacity-60">
      &copy; {year} Maisterpiece
    </span>

    <!-- Center: tagline -->
    <span class="label hidden md:block opacity-50">
      Handcrafted Ceramics &amp; Soaps — Slovakia
    </span>

    <!-- Nav -->
    <nav class="flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="label hover:opacity-50 transition-opacity">
          {label}
        </a>
      ))}
    </nav>

  </div>
</footer>
