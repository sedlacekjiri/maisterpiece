---
const year = new Date().getFullYear();
const links = [
  { href: '#portfolio', label: 'Portfolio' },
  { href: '#shop',      label: 'Shop'      },
  { href: '#about',     label: 'About'     },
  { href: '#contact',   label: 'Contact'   },
];
---

<footer class="bg-ink text-cream-300 pt-20 pb-10">
  <div class="container-site">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 pb-16 border-b border-cream-200/10">

      <!-- Brand -->
      <div class="space-y-4">
        <a href="/" class="font-serif text-2xl text-cream-100 hover:text-clay-300 transition-colors">
          Maisterpiece
        </a>
        <p class="font-sans text-sm leading-relaxed text-cream-500 max-w-xs">
          Handcrafted pottery and artisan goods made with intention. Each piece carries the warmth of human hands.
        </p>
      </div>

      <!-- Navigation -->
      <div class="space-y-4">
        <p class="section-label text-cream-500">Explore</p>
        <nav class="flex flex-col gap-3">
          {links.map(({ href, label }) => (
            <a
              href={href}
              class="font-sans text-sm text-cream-400 hover:text-cream-100 transition-colors w-fit"
            >
              {label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact -->
      <div class="space-y-4">
        <p class="section-label text-cream-500">Get in Touch</p>
        <div class="space-y-2">
          <a
            href="mailto:hello@maisterpiece.art"
            class="font-sans text-sm text-cream-400 hover:text-cream-100 transition-colors block"
          >
            hello@maisterpiece.art
          </a>
          <p class="font-sans text-sm text-cream-500">Slovakia</p>
        </div>
        <!-- Social links -->
        <div class="flex gap-4 pt-2">
          <a
            href="https://www.instagram.com/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="text-cream-500 hover:text-cream-100 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a
            href="https://www.pinterest.com/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Pinterest"
            class="text-cream-500 hover:text-cream-100 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.23-5.22 1.23-5.22s-.31-.63-.31-1.56c0-1.46.85-2.55 1.9-2.55.9 0 1.33.67 1.33 1.48 0 .9-.58 2.26-.87 3.51-.25 1.05.52 1.9 1.55 1.9 1.86 0 3.29-1.96 3.29-4.8 0-2.51-1.8-4.26-4.38-4.26-2.98 0-4.73 2.24-4.73 4.55 0 .9.35 1.87.78 2.4.09.1.1.19.07.3-.08.32-.25 1.05-.29 1.19-.05.19-.16.23-.37.14-1.39-.65-2.26-2.68-2.26-4.32 0-3.51 2.55-6.74 7.35-6.74 3.86 0 6.86 2.75 6.86 6.42 0 3.83-2.41 6.91-5.76 6.91-1.13 0-2.19-.59-2.55-1.28l-.69 2.59c-.25.97-.93 2.18-1.39 2.92.96.3 1.99.46 3.04.46 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-8">
      <p class="font-sans text-xs text-cream-600">
        &copy; {year} Maisterpiece. All rights reserved.
      </p>
      <p class="font-sans text-xs text-cream-600">
        Handmade with care &mdash; each piece is one of a kind.
      </p>
    </div>
  </div>
</footer>
