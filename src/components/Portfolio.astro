---
const works = [
  { id: '01', title: 'Ash-glaze Serving Bowl', category: 'Pottery', year: '2024', bg: '#C8C3BA' },
  { id: '02', title: 'Wabi-sabi Vase Series',  category: 'Pottery', year: '2024', bg: '#BEB9B0' },
  { id: '03', title: 'Espresso Cup Set',        category: 'Pottery', year: '2023', bg: '#C4BEB5' },
  { id: '04', title: 'Salt Bar Soap Quartet',   category: 'Soap',    year: '2024', bg: '#D0CAC1' },
  { id: '05', title: 'Stoneware Dinner Plates', category: 'Pottery', year: '2024', bg: '#B8B3AB' },
  { id: '06', title: 'Botanical Soap Set',      category: 'Soap',    year: '2023', bg: '#D4CFC8' },
];
---

<section id="work" class="border-t border-[#0A0A0A]/15 py-20 md:py-28">

  <!-- Section header -->
  <div class="flex items-baseline justify-between px-6 md:px-10 mb-12">
    <p class="label opacity-40">(02)</p>
    <p class="label">Selected Work</p>
    <p class="label opacity-40">{works.length} pieces</p>
  </div>

  <!-- Work grid -->
  <div class="px-6 md:px-10 grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
    {works.map((work) => (
      <article class="group cursor-default reveal">
        <!-- Image placeholder -->
        <div
          class="w-full aspect-[3/4] mb-3 relative overflow-hidden"
          style={`background-color: ${work.bg};`}
        >
          <img
            src={`/maisterpiece/images/portfolio-${work.id}.jpg`}
            alt={work.title}
            class="w-full h-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100 absolute inset-0"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        </div>
        <!-- Caption -->
        <p class="label mb-1 opacity-40">{work.category} — {work.year}</p>
        <p class="label">{work.title}</p>
      </article>
    ))}
  </div>

  <!-- Footer row -->
  <div class="px-6 md:px-10 mt-14 flex items-center justify-between border-t border-[#0A0A0A]/10 pt-6">
    <p class="label opacity-40">Commission a custom piece</p>
    <a href="#contact" class="label hover:opacity-50 transition-opacity">
      Get in touch →
    </a>
  </div>

</section>
