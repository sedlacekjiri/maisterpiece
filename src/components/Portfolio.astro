---
const works = [
  {
    id: 1,
    title:    'Ash-glaze Serving Bowl',
    category: 'Pottery',
    year:     '2024',
    desc:     'Wheel-thrown stoneware, natural wood-ash glaze, food safe.',
    image:    '/images/portfolio-01.jpg',
    wide:     true,
  },
  {
    id: 2,
    title:    'Wabi-sabi Vase Series',
    category: 'Pottery',
    year:     '2024',
    desc:     'Hand-pinched earthenware, matte finish.',
    image:    '/images/portfolio-02.jpg',
    wide:     false,
  },
  {
    id: 3,
    title:    'Espresso Cup Set',
    category: 'Pottery',
    year:     '2023',
    desc:     'Set of four, off-white slip with iron oxide.',
    image:    '/images/portfolio-03.jpg',
    wide:     false,
  },
  {
    id: 4,
    title:    'Salt Bar Soap Quartet',
    category: 'Soap',
    year:     '2024',
    desc:     'Cold process, lavender & clay, natural colorants.',
    image:    '/images/portfolio-04.jpg',
    wide:     false,
  },
  {
    id: 5,
    title:    'Stoneware Dinner Plates',
    category: 'Pottery',
    year:     '2024',
    desc:     'Set of two, organic rim, blush-toned slip.',
    image:    '/images/portfolio-05.jpg',
    wide:     false,
  },
  {
    id: 6,
    title:    'Botanical Soap Collection',
    category: 'Soap',
    year:     '2023',
    desc:     'Goat milk base, dried botanicals, unscented option.',
    image:    '/images/portfolio-06.jpg',
    wide:     true,
  },
];
---

<section id="portfolio" class="py-28 md:py-36 bg-cream-100">
  <div class="container-site">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
      <div class="reveal">
        <p class="section-label mb-3">Selected works</p>
        <h2 class="font-serif font-light text-heading text-ink">
          Portfolio
        </h2>
        <div class="divider mt-5 animate-line-grow"></div>
      </div>
      <p class="font-sans text-sm text-ink-muted max-w-xs leading-relaxed reveal">
        A curated selection of pottery, ceramics, and handcrafted soap — made one piece at a time.
      </p>
    </div>

    <!-- Masonry-style grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
      {works.map((work, i) => (
        <article
          class={`group relative overflow-hidden bg-cream-200 reveal
                  ${work.wide ? 'sm:col-span-2' : ''}`}
          style={`transition-delay: ${i * 80}ms`}
        >
          <!-- Image -->
          <div class="relative overflow-hidden aspect-[4/5]">
            <img
              src={work.image}
              alt={work.title}
              class="w-full h-full object-cover transition-transform duration-700 ease-out
                     group-hover:scale-105"
              loading="lazy"
              width="600"
              height="750"
            />
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/30 transition-all duration-500 flex items-end p-6">
              <div class="translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-400">
                <p class="font-sans text-xs tracking-widest uppercase text-cream-300 mb-1">
                  {work.category} · {work.year}
                </p>
                <p class="font-serif text-lg text-cream-100">{work.title}</p>
              </div>
            </div>
          </div>

          <!-- Caption (visible on mobile without hover) -->
          <div class="block sm:hidden p-4 bg-cream-200">
            <p class="section-label text-[10px] mb-1">{work.category} · {work.year}</p>
            <p class="font-serif text-base text-ink">{work.title}</p>
            <p class="font-sans text-xs text-ink-muted mt-1">{work.desc}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- View more link -->
    <div class="mt-16 text-center reveal">
      <a href="#contact" class="btn-outline">
        Commission a custom piece
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
