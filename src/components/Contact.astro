---
// Contact section
---

<section id="contact" class="border-t border-[#0A0A0A]/15 py-20 md:py-28">

  <!-- Section header -->
  <div class="flex items-baseline justify-between px-6 md:px-10 mb-12">
    <p class="label opacity-40">(05)</p>
    <p class="label">Contact</p>
    <p class="label opacity-40">Let's talk</p>
  </div>

  <div class="px-6 md:px-10 grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">

    <!-- Info -->
    <div class="space-y-6 reveal">
      <p class="label leading-loose opacity-70 max-w-xs">
        Custom commission, wholesale enquiry, or just a hello?
        Fill in the form and I'll get back to you.
      </p>
      <div class="space-y-3 pt-2 border-t border-[#0A0A0A]/10">
        <div>
          <p class="label opacity-40 mb-0.5">Email</p>
          <a href="mailto:hello@maisterpiece.art" class="label hover:opacity-50 transition-opacity">
            hello@maisterpiece.art
          </a>
        </div>
        <div>
          <p class="label opacity-40 mb-0.5">Instagram</p>
          <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer" class="label hover:opacity-50 transition-opacity">
            @maisterpiece.art
          </a>
        </div>
        <div>
          <p class="label opacity-40 mb-0.5">Location</p>
          <p class="label">Slovakia, Central Europe</p>
        </div>
      </div>
    </div>

    <!-- Form -->
    <div class="reveal">
      <form
        action="https://formspree.io/f/your-form-id"
        method="POST"
        id="contact-form"
        class="space-y-6"
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="label opacity-40 block mb-2">Name</label>
            <input
              id="name" name="name" type="text" required autocomplete="name"
              placeholder="Your name"
              class="w-full bg-transparent border-b border-[#0A0A0A]/25 text-[#0A0A0A] label py-2 px-0 placeholder-[#0A0A0A]/25 focus:outline-none focus:border-[#0A0A0A]/70 transition-colors"
            />
          </div>
          <div>
            <label for="email" class="label opacity-40 block mb-2">Email</label>
            <input
              id="email" name="email" type="email" required autocomplete="email"
              placeholder="you@example.com"
              class="w-full bg-transparent border-b border-[#0A0A0A]/25 text-[#0A0A0A] label py-2 px-0 placeholder-[#0A0A0A]/25 focus:outline-none focus:border-[#0A0A0A]/70 transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="subject" class="label opacity-40 block mb-2">Subject</label>
          <select
            id="subject" name="subject"
            class="w-full bg-transparent border-b border-[#0A0A0A]/25 text-[#0A0A0A] label py-2 px-0 focus:outline-none focus:border-[#0A0A0A]/70 transition-colors cursor-pointer appearance-none"
          >
            <option value="" disabled selected>Select a topic</option>
            <option value="custom-commission">Custom commission</option>
            <option value="wholesale">Wholesale enquiry</option>
            <option value="order-question">Order question</option>
            <option value="general">General hello</option>
          </select>
        </div>

        <div>
          <label for="message" class="label opacity-40 block mb-2">Message</label>
          <textarea
            id="message" name="message" rows="4" required
            placeholder="Tell me what you have in mind…"
            class="w-full bg-transparent border-b border-[#0A0A0A]/25 text-[#0A0A0A] label py-2 px-0 placeholder-[#0A0A0A]/25 resize-none focus:outline-none focus:border-[#0A0A0A]/70 transition-colors"
          ></textarea>
        </div>

        <button
          type="submit"
          class="label border border-[#0A0A0A]/30 px-6 py-3 hover:bg-[#0A0A0A] hover:text-[#F5F0E4] transition-all duration-150"
        >
          Send message →
        </button>

        <p id="form-success" class="hidden label opacity-60">Thank you! I'll be in touch soon.</p>
        <p id="form-error"   class="hidden label opacity-60">Something went wrong. Please email me directly.</p>
      </form>
    </div>

  </div>

</section>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success')!;
  const error   = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch(form.action, {
        method: 'POST', body: data, headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.reset();
        success.classList.remove('hidden');
        error.classList.add('hidden');
      } else throw new Error();
    } catch {
      error.classList.remove('hidden');
      success.classList.add('hidden');
    }
  });
</script>
