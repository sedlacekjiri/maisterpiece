---
// About section
---

<section id="about" class="border-t border-[#0A0A0A]/15 py-20 md:py-28">

  <!-- Section header -->
  <div class="flex items-baseline justify-between px-6 md:px-10 mb-12">
    <p class="label opacity-40">(04)</p>
    <p class="label">About</p>
    <p class="label opacity-40">The maker</p>
  </div>

  <!-- Content: two columns -->
  <div class="px-6 md:px-10 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">

    <!-- Artist image -->
    <div class="w-full aspect-[3/4] max-w-sm reveal overflow-hidden" style="background-color: #C8C3BA;">
      <img
        src="https://cdn.prod.website-files.com/658f544331d16c0a01bd6937/658f55f5a9472f9ecd3e34e3_411555814_1290694265659619_5367797692436190560_n.jpg"
        alt="Maja — ceramic artist"
        class="w-full h-full object-cover object-top"
        loading="lazy"
      />
    </div>

    <!-- Bio text -->
    <div class="reveal space-y-8 pt-2">

      <div class="space-y-4">
        <p class="label leading-loose opacity-80 max-w-sm">
          Hi, I'm Maja — a ceramic artist and crafter originally from Poland,
          now based in Iceland. I started throwing pottery at my kitchen table
          and eventually turned the spare room into a proper studio.
        </p>
        <p class="label leading-loose opacity-60 max-w-sm">
          My work is rooted in the Japanese concept of wabi-sabi — finding
          beauty in the imperfect, impermanent, and incomplete. No two pieces
          are exactly alike.
        </p>
        <p class="label leading-loose opacity-60 max-w-sm">
          Alongside ceramics, I work with other materials and crafts —
          always small-batch, always by hand.
        </p>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-3 gap-6 pt-4 border-t border-[#0A0A0A]/10">
        {[
          { n: '8+',   l: 'Years' },
          { n: '200+', l: 'Pieces' },
          { n: '100%', l: 'Handmade' },
        ].map(({ n, l }) => (
          <div>
            <p class="label text-[20px] mb-1">{n}</p>
            <p class="label opacity-40">{l}</p>
          </div>
        ))}
      </div>

      <a href="#contact" class="label inline-block border border-[#0A0A0A]/30 px-5 py-3 hover:bg-[#0A0A0A] hover:text-[#F5F0E4] transition-all duration-150">
        Work with me →
      </a>
    </div>

  </div>

</section>
