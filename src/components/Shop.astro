---
const products = [
  {
    id: '01',
    name:       'Ash-glaze Serving Bowl',
    category:   'Pottery',
    price:      '€ 68',
    bg:         '#C8C3BA',
    shopifyUrl: 'https://your-store.myshopify.com/products/ash-glaze-bowl',
    soldOut:    false,
  },
  {
    id: '02',
    name:       'Wabi-sabi Vase — Small',
    category:   'Pottery',
    price:      '€ 42',
    bg:         '#BEB9B0',
    shopifyUrl: 'https://your-store.myshopify.com/products/wabi-vase-small',
    soldOut:    false,
  },
  {
    id: '03',
    name:       'Espresso Cup',
    category:   'Pottery',
    price:      '€ 32',
    bg:         '#C4BEB5',
    shopifyUrl: 'https://your-store.myshopify.com/products/espresso-cup',
    soldOut:    false,
  },
  {
    id: '04',
    name:       'Lavender & Clay Soap',
    category:   'Soap',
    price:      '€ 12',
    bg:         '#D0CAC1',
    shopifyUrl: 'https://your-store.myshopify.com/products/lavender-clay-soap',
    soldOut:    false,
  },
  {
    id: '05',
    name:       'Goat Milk Rose Soap',
    category:   'Soap',
    price:      '€ 13',
    bg:         '#B8B3AB',
    shopifyUrl: 'https://your-store.myshopify.com/products/goat-milk-rose-soap',
    soldOut:    false,
  },
  {
    id: '06',
    name:       'Soap Gift Set — 3 bars',
    category:   'Soap',
    price:      '€ 34',
    bg:         '#D4CFC8',
    shopifyUrl: 'https://your-store.myshopify.com/products/soap-gift-set',
    soldOut:    false,
  },
];
---

<section id="shop" class="border-t border-[#0A0A0A]/15 py-20 md:py-28">

  <!-- Section header -->
  <div class="flex items-baseline justify-between px-6 md:px-10 mb-12">
    <p class="label opacity-40">(03)</p>
    <p class="label">Shop</p>
    <p class="label opacity-40">Available now</p>
  </div>

  <!-- Filter row -->
  <div class="px-6 md:px-10 flex gap-6 mb-10 border-b border-[#0A0A0A]/10 pb-4">
    {['All', 'Pottery', 'Soap'].map((cat, i) => (
      <button
        data-filter={cat}
        class={`filter-btn label transition-opacity ${i === 0 ? 'opacity-100' : 'opacity-40'} hover:opacity-100`}
      >
        {cat}
      </button>
    ))}
  </div>

  <!-- Product list: table-like rows -->
  <div id="product-grid" class="px-6 md:px-10 divide-y divide-[#0A0A0A]/10">
    {products.map((p) => (
      <article
        class="product-card flex items-center gap-6 py-5 group"
        data-category={p.category}
      >
        <!-- Thumbnail -->
        <div
          class="flex-shrink-0 w-14 h-14 md:w-16 md:h-16 relative overflow-hidden"
          style={`background-color: ${p.bg};`}
        >
          <img
            src={`/maisterpiece/images/shop-${p.id}.jpg`}
            alt={p.name}
            class="w-full h-full object-cover absolute inset-0 opacity-0"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        </div>

        <!-- Name + category -->
        <div class="flex-1 min-w-0">
          <p class="label mb-0.5 opacity-40">{p.category}</p>
          <p class="label">{p.name}</p>
        </div>

        <!-- Price -->
        <span class="label shrink-0 hidden sm:block">{p.price}</span>

        <!-- CTA -->
        {p.soldOut ? (
          <span class="label opacity-30 shrink-0">Sold out</span>
        ) : (
          <a
            href={p.shopifyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="label shrink-0 border border-[#0A0A0A]/30 px-4 py-2 hover:bg-[#0A0A0A] hover:text-[#F5F0E4] hover:border-[#0A0A0A] transition-all duration-150"
          >
            Buy →
          </a>
        )}
      </article>
    ))}
  </div>

  <p class="px-6 md:px-10 mt-8 label opacity-30">
    Payments via Shopify. Shipping within the EU.
  </p>

</section>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards      = document.querySelectorAll<HTMLElement>('.product-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.filter!;
      filterBtns.forEach((b) => b.classList.replace('opacity-100', 'opacity-40'));
      btn.classList.replace('opacity-40', 'opacity-100');
      cards.forEach((card) => {
        const match = cat === 'All' || card.dataset.category === cat;
        (card as HTMLElement).style.display = match ? '' : 'none';
      });
    });
  });
</script>
