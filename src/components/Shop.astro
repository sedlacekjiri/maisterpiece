---
import { products } from '../data/products';
const base = import.meta.env.BASE_URL;
---

<section id="shop" class="border-t border-[#0A0A0A]/15 py-20 md:py-28">

  <!-- Section header -->
  <div class="flex items-baseline justify-between px-6 md:px-10 mb-12">
    <p class="label opacity-40">(03)</p>
    <p class="label">Shop</p>
    <p class="label opacity-40">Available now</p>
  </div>

  <!-- Filter row -->
  <div class="px-6 md:px-10 flex gap-6 mb-10 border-b border-[#0A0A0A]/10 pb-4">
    {['All', 'Pottery', 'Soap'].map((cat, i) => (
      <button
        data-filter={cat}
        class={`filter-btn label transition-opacity ${i === 0 ? 'opacity-100' : 'opacity-40'} hover:opacity-100`}
      >
        {cat}
      </button>
    ))}
  </div>

  <!-- Product card grid -->
  <div id="product-grid" class="px-6 md:px-10 grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
    {products.map((p) => (
      <article class="product-card group reveal" data-category={p.category}>

        <!-- Image -->
        <a href={`${base}products/${p.slug}`} class="block w-full aspect-[3/4] mb-4 relative overflow-hidden" style={`background-color: ${p.bg};`}>
          {p.image && (
            <img
              src={p.image}
              alt={p.name}
              class="w-full h-full object-cover absolute inset-0 transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          )}
          {p.soldOut && (
            <div class="absolute inset-0 bg-[#F5F0E4]/60 flex items-center justify-center">
              <span class="label">Sold out</span>
            </div>
          )}
        </a>

        <!-- Info -->
        <p class="label mb-1 opacity-40">{p.category}</p>
        <p class="label mb-3">{p.name}</p>
        <p class="label mb-4">{p.price}</p>

        <!-- Actions -->
        <div class="flex gap-3">
          <a
            href={`${base}products/${p.slug}`}
            class="label flex-1 text-center border border-[#0A0A0A]/30 px-4 py-2 hover:bg-[#0A0A0A]/5 transition-colors duration-150"
          >
            Detail
          </a>
          {!p.soldOut && (
            <a
              href={p.shopifyUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="label flex-1 text-center border border-[#0A0A0A] px-4 py-2 bg-[#0A0A0A] text-[#F5F0E4] hover:bg-transparent hover:text-[#0A0A0A] transition-all duration-150"
            >
              Buy →
            </a>
          )}
        </div>

      </article>
    ))}
  </div>

  <p class="px-6 md:px-10 mt-12 label opacity-30">
    Payments via Shopify. Shipping within the EU.
  </p>

</section>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards      = document.querySelectorAll<HTMLElement>('.product-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.filter!;
      filterBtns.forEach((b) => b.classList.replace('opacity-100', 'opacity-40'));
      btn.classList.replace('opacity-40', 'opacity-100');
      cards.forEach((card) => {
        const match = cat === 'All' || card.dataset.category === cat;
        (card as HTMLElement).style.display = match ? '' : 'none';
      });
    });
  });
</script>
