---
const partners = [
  {
    name: 'Kaffifélagid',
    logo: 'https://cdn.prod.website-files.com/658f544331d16c0a01bd6937/69bd3085ad6a05df319732c0_kaffife%CC%81lagid.JPG',
    dark: false,
  },
  {
    name: 'Bus 1',
    logo: 'https://cdn.prod.website-files.com/658f544331d16c0a01bd6937/69bd30ac694d20260c3121f4_Bus%2B1%2BWhite-1.webp',
    dark: true,
  },
];
---

<section class="border-b border-[#0A0A0A]/10">
  <div class="px-6 md:px-10 py-10 flex flex-col md:flex-row md:items-center gap-8 md:gap-16">

    <p class="label opacity-40 shrink-0">Stocked at</p>

    <div class="flex flex-wrap items-center gap-8 md:gap-12">
      {partners.map(({ name, logo, dark }) => (
        <div class={`flex items-center justify-center h-10 ${dark ? 'bg-[#0A0A0A] px-4 rounded' : ''}`}>
          <img
            src={logo}
            alt={name}
            class="h-full w-auto object-contain"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>
