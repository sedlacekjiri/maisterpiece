---
const navLinks = [
  { href: '#portfolio', label: 'Portfolio' },
  { href: '#shop',      label: 'Shop'      },
  { href: '#about',     label: 'About'     },
  { href: '#contact',   label: 'Contact'   },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <div class="container-site">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a
        href="/"
        class="font-serif text-xl md:text-2xl tracking-wide text-ink hover:text-clay-500 transition-colors"
        aria-label="Maisterpiece — Home"
      >
        Maisterpiece
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="font-sans text-xs tracking-[0.18em] uppercase text-ink-light
                   hover:text-clay-500 transition-colors duration-200"
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Mobile menu toggle -->
      <button
        id="menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        class="md:hidden flex flex-col gap-1.5 p-2 -mr-2"
      >
        <span class="menu-bar block w-6 h-px bg-ink transition-all duration-300"></span>
        <span class="menu-bar block w-6 h-px bg-ink transition-all duration-300"></span>
        <span class="menu-bar block w-4 h-px bg-ink transition-all duration-300 self-end"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-cream-100 flex flex-col items-center justify-center
         opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <nav class="flex flex-col items-center gap-8" aria-label="Mobile navigation">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class="mobile-nav-link font-serif text-3xl text-ink hover:text-clay-500 transition-colors"
      >
        {label}
      </a>
    ))}
  </nav>
</div>

<script>
  const header    = document.getElementById('site-header')!;
  const toggle    = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bars      = toggle.querySelectorAll('.menu-bar');

  // Scroll effect
  let lastY = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > 60) {
      header.classList.add('bg-cream-100/95', 'backdrop-blur-md', 'shadow-sm');
    } else {
      header.classList.remove('bg-cream-100/95', 'backdrop-blur-md', 'shadow-sm');
    }
    lastY = y;
  }, { passive: true });

  // Mobile menu
  let open = false;
  toggle.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));
    mobileMenu.setAttribute('aria-hidden', String(!open));
    if (open) {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100');
      bars[0].classList.add('rotate-45', 'translate-y-2');
      bars[1].classList.add('-rotate-45');
      bars[2].classList.add('opacity-0');
    } else {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100');
      bars[0].classList.remove('rotate-45', 'translate-y-2');
      bars[1].classList.remove('-rotate-45');
      bars[2].classList.remove('opacity-0');
    }
  });

  // Close on nav click
  mobileMenu.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100');
      bars[0].classList.remove('rotate-45', 'translate-y-2');
      bars[1].classList.remove('-rotate-45');
      bars[2].classList.remove('opacity-0');
    });
  });
</script>
