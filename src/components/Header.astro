---
const navLinks = [
  { href: '#work',    label: 'Work'    },
  { href: '#shop',    label: 'Shop'    },
  { href: '#about',   label: 'About'   },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-[#F5F0E4] border-b border-[#0A0A0A]/15">
  <div class="flex items-center justify-between px-6 md:px-10 h-11">

    <!-- Brand -->
    <a href="/" class="label hover:opacity-50 transition-opacity">
      Maisterpiece
    </a>

    <!-- Center: logo -->
    <a href="/">
      <img
        src="https://cdn.prod.website-files.com/658f544331d16c0a01bd6937/69bc6715491f5f016705a37c_Grafika_bez_nazwy%202.PNG"
        alt="Maisterpiece"
        class="h-9 w-auto"
      />
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="label hover:opacity-50 transition-opacity">
          {label}
        </a>
      ))}
    </nav>

    <!-- Mobile: hamburger -->
    <button
      id="menu-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      class="md:hidden label"
    >
      Menu
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-[#F5F0E4] flex flex-col pt-11 opacity-0 pointer-events-none transition-opacity duration-200"
  aria-hidden="true"
>
  <div class="border-b border-[#0A0A0A]/15 h-px w-full"></div>
  <nav class="flex flex-col px-6 pt-10 gap-8">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class="mobile-nav-link label text-[22px] tracking-wider"
      >
        {label}
      </a>
    ))}
  </nav>
</div>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  let open = false;

  toggle.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));
    menu.setAttribute('aria-hidden', String(!open));
    toggle.textContent = open ? 'Close' : 'Menu';
    if (open) {
      menu.classList.remove('opacity-0', 'pointer-events-none');
    } else {
      menu.classList.add('opacity-0', 'pointer-events-none');
    }
  });

  menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      toggle.textContent = 'Menu';
      menu.classList.add('opacity-0', 'pointer-events-none');
    });
  });

</script>
