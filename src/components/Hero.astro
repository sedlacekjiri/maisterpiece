---
// Hero — fullscreen on mobile, editorial contained photo on desktop
---

<section id="work" class="h-screen flex flex-col relative overflow-hidden bg-[#F5F0E4]">

  <!-- Photo: fullscreen on mobile, contained on desktop -->
  <img
    src="https://cdn.prod.website-files.com/687ebffd20183c0459d68784/69bc350652c6dc86ba0f942e_5Q2A8467.JPG"
    alt="Maja's ceramic work"
    class="absolute inset-0 w-full h-full object-cover md:top-[14%] md:bottom-[15%] md:left-[35%] md:right-[3%] md:w-[62%] md:h-[71%]"
    fetchpriority="high"
  />

  <!-- Mobile-only vignette so text is readable -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/40 pointer-events-none md:hidden z-10"></div>

  <!-- Top-left: project meta -->
  <div class="relative px-6 md:px-10 pt-14 pb-8 z-20">
    <p class="label mb-4 text-[#F5F0E4] md:text-ink opacity-60">(01)</p>
    <p class="label leading-loose text-[#F5F0E4] md:text-ink opacity-90 max-w-[220px]">
      Handcrafted ceramics<br>
      &amp; other craft,<br>
      made in Iceland.
    </p>
  </div>

  <!-- Bottom corners: pinned absolutely -->
  <div class="absolute bottom-0 left-0 right-0 flex items-end justify-between px-6 md:px-10 pb-8 z-20">
    <a href="#shop" class="label text-[#F5F0E4] md:text-ink hover:opacity-50 transition-opacity">
      Shop the collection →
    </a>
    <a href="#work" class="label text-[#F5F0E4] md:text-ink opacity-50 hover:opacity-90 transition-opacity">
      Scroll ↓
    </a>
  </div>

</section>
