---
// Placeholder image strip items: [width, height, bg-tone, label]
const strip = [
  { w: '96px',  h: '112px', bg: '#D4CFC8', label: 'Bowl I'    },
  { w: '128px', h: '144px', bg: '#BEB9B0', label: 'Vase II'   },
  { w: '192px', h: '260px', bg: '#C8C3BA', label: 'Featured'  },
  { w: '112px', h: '128px', bg: '#B8B3AB', label: 'Craft I'   },
  { w: '144px', h: '144px', bg: '#C4BEB5', label: 'Cup III'   },
  { w: '112px', h: '112px', bg: '#AEA9A1', label: 'Platter'   },
  { w: '128px', h: '128px', bg: '#D0CAC1', label: 'Craft II'  },
  { w: '96px',  h: '96px',  bg: '#B4AFA7', label: 'Bowl IV'   },
];
---

<section id="work" class="h-screen flex flex-col relative">

  <!-- Project meta -->
  <div class="px-6 md:px-10 pt-14 pb-8">
    <p class="label mb-4 opacity-40">(01)</p>
    <p class="label leading-loose opacity-80 max-w-[220px]">
      Handcrafted ceramics<br>
      &amp; other craft,<br>
      made in Iceland.
    </p>
  </div>

  <!-- Horizontal image strip — centered vertically in remaining space -->
  <div class="flex-1 flex items-center">
    <div
      class="strip-scroll flex items-end gap-3 px-6 md:px-10 w-full overflow-x-auto pb-2"
    >
      {strip.map((item) => (
        <div
          class="flex-shrink-0 relative overflow-hidden"
          style={`width: ${item.w}; height: ${item.h}; background-color: ${item.bg};`}
        >
          <span class="sr-only">{item.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom corners: pinned absolutely -->
  <div class="absolute bottom-0 left-0 right-0 flex items-end justify-between px-6 md:px-10 pb-8">
    <a href="#shop" class="label hover:opacity-50 transition-opacity">
      Shop the collection →
    </a>
    <a href="#work" class="label opacity-40 hover:opacity-80 transition-opacity">
      Scroll ↓
    </a>
  </div>

</section>

<style>
  .strip-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .strip-scroll::-webkit-scrollbar {
    display: none;
  }
</style>
