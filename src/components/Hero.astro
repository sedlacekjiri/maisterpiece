---
// Hero — full-screen background image
---

<section id="work" class="h-screen flex flex-col relative overflow-hidden">

  <!-- Full-screen background image -->
  <img
    src="https://cdn.prod.website-files.com/687ebffd20183c0459d68784/69bc350652c6dc86ba0f942e_5Q2A8467.JPG"
    alt="Maja's ceramic work"
    class="absolute inset-0 w-full h-full object-cover object-center"
    fetchpriority="high"
  />

  <!-- Subtle dark vignette so text is readable -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/30 pointer-events-none"></div>

  <!-- Top-left: project meta -->
  <div class="relative px-6 md:px-10 pt-14 pb-8 z-10">
    <p class="label mb-4 text-[#F5F0E4] opacity-60">(01)</p>
    <p class="label leading-loose text-[#F5F0E4] opacity-90 max-w-[220px]">
      Handcrafted ceramics<br>
      &amp; other craft,<br>
      made in Iceland.
    </p>
  </div>

  <!-- Bottom corners: pinned absolutely -->
  <div class="absolute bottom-0 left-0 right-0 flex items-end justify-between px-6 md:px-10 pb-8 z-10">
    <a href="#shop" class="label text-[#F5F0E4] hover:opacity-50 transition-opacity">
      Shop the collection →
    </a>
    <a href="#work" class="label text-[#F5F0E4] opacity-50 hover:opacity-90 transition-opacity">
      Scroll ↓
    </a>
  </div>

</section>
